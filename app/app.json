{
  "expo": {
    "name": "seeker-iou",
    "slug": "seeker-iou",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "seeker-iou",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "android": {
      "package": "com.seekeriou.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "android.permission.NFC",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "newArchEnabled": true
          }
        }
      ],
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "NFC is required for offline payments",
          "selectIdentifiers": [],
          "systemCodes": []
        }
      ]
    ]
  }
}
