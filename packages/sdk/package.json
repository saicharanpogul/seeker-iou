{
  "name": "seeker-iou",
  "version": "0.1.0",
  "description": "TypeScript SDK for seeker-iou on-chain vault and settlement protocol",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saicharanpogul/seeker-iou.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "solana",
    "seeker",
    "iou",
    "nfc",
    "offline-payments",
    "vault",
    "settlement"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "borsh": "^2.0.0",
    "seeker-sdk": "^0.2.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.0.0"
  }
}
